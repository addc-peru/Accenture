{
	"name": "CopiarCsvTiendas",
	"properties": {
		"folder": {
			"name": "Dataflow Atenciones"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_tiendas",
						"type": "DatasetReference"
					},
					"name": "BaseTiendasLanding"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adls_tiendas",
						"type": "DatasetReference"
					},
					"name": "BaseTiendasBronze"
				}
			],
			"transformations": [
				{
					"name": "ColumnasRequeridas"
				},
				{
					"name": "ColumnasUtiles"
				}
			],
			"scriptLines": [
				"parameters{",
				"     FileName as string (\"Tienda Walmart.csv\")",
				"}",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> BaseTiendasLanding",
				"BaseTiendasLanding derive(detalle_id = byName(\"Detalle_ID\"),",
				"          factura = byName(\"Factura\"),",
				"          producto_id = byName(\"Producto_ID\"),",
				"          unidades = byName(\"Unidades\"),",
				"          precio_unitario = byName(\"Precio_Unitario\"),",
				"          file_name = $FileName) ~> ColumnasRequeridas",
				"ColumnasRequeridas select(mapColumn(",
				"          detalle_id,",
				"          factura,",
				"          producto_id,",
				"          unidades,",
				"          precio_unitario,",
				"          file_name",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> ColumnasUtiles",
				"ColumnasUtiles sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:[($FileName)],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> BaseTiendasBronze"
			]
		}
	}
}