{
	"name": "ETL Tickets",
	"properties": {
		"folder": {
			"name": "Dataflow Atenciones"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_tickets_lima",
						"type": "DatasetReference"
					},
					"name": "TicketsLima"
				},
				{
					"dataset": {
						"referenceName": "ds_adls_tickets_provincia",
						"type": "DatasetReference"
					},
					"name": "TicketsProvincia"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adls_tickets_parquet",
						"type": "DatasetReference"
					},
					"name": "TicketsParquet"
				}
			],
			"transformations": [
				{
					"name": "AsignarTipoDato"
				},
				{
					"name": "SeleccionarColumnas"
				},
				{
					"name": "UnirDatasets"
				},
				{
					"name": "ColumnasCalculadas"
				},
				{
					"name": "ColumnasUtiles"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Numero Ticket} as string,",
				"          ItemID as integer,",
				"          Item as string,",
				"          {Fecha Creacion} as date 'yyyy-MM-dd',",
				"          {Fecha Termino} as date 'dd/MM/yyyy',",
				"          {Fecha Cierre} as date 'dd-MM-yy',",
				"          Resumen as string,",
				"          Ubicacion as string,",
				"          {Modo Reporte} as string,",
				"          Estado as string,",
				"          Prioridad as string,",
				"          Region as string,",
				"          FechaImportacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> TicketsLima",
				"source(output(",
				"          NumeroTicket as string,",
				"          ItemID as integer,",
				"          Item as string,",
				"          FechaCreacion as string,",
				"          FechaTermino as string,",
				"          FechaCierre as string,",
				"          Resumen as string,",
				"          Ubicacion as string,",
				"          ModoReporte as string,",
				"          Estado as string,",
				"          Region as string,",
				"          FechaImportacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'documentPerLine') ~> TicketsProvincia",
				"TicketsProvincia cast(output(",
				"          FechaCreacion as date 'yyyy-MM-dd',",
				"          FechaTermino as date 'dd/MM/yyyy',",
				"          FechaCierre as date 'dd-MM-yy'",
				"     ),",
				"     errors: true) ~> AsignarTipoDato",
				"TicketsLima select(mapColumn(",
				"          NumeroTicket = {Numero Ticket},",
				"          ItemID,",
				"          Item,",
				"          FechaCreacion = {Fecha Creacion},",
				"          FechaTermino = {Fecha Termino},",
				"          FechaCierre = {Fecha Cierre},",
				"          Resumen,",
				"          Ubicacion,",
				"          ModoReporte = {Modo Reporte},",
				"          Estado,",
				"          Region,",
				"          FechaImportacion",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> SeleccionarColumnas",
				"SeleccionarColumnas, AsignarTipoDato union(byName: true)~> UnirDatasets",
				"UnirDatasets derive(fecha_cierre = coalesce(FechaTermino, FechaCierre),",
				"          estado = iif(Estado == \"Terminado\", \"Cerrado\", Estado),",
				"          agencia_id = toInteger(trim(substringIndex(Ubicacion, \"-\", -1))),",
				"          fecha_carga = currentUTC()) ~> ColumnasCalculadas",
				"ColumnasCalculadas select(mapColumn(",
				"          numero_ticket = NumeroTicket,",
				"          agencia_id,",
				"          fecha_creacion = FechaCreacion,",
				"          fecha_cierre,",
				"          item = Item,",
				"          item_id = ItemID,",
				"          resumen = Resumen,",
				"          modo_reporte = ModoReporte,",
				"          region = Region,",
				"          estado = ColumnasCalculadas@estado,",
				"          fecha_carga",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ColumnasUtiles",
				"ColumnasUtiles sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          numero_ticket as string,",
				"          agencia_id as integer,",
				"          fecha_creacion as date,",
				"          fecha_cierre as date,",
				"          item as string,",
				"          item_id as integer,",
				"          resumen as string,",
				"          modo_reporte as string,",
				"          region as string,",
				"          estado as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     format: 'parquet',",
				"     partitionFileNames:['Tickets.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> TicketsParquet"
			]
		}
	}
}