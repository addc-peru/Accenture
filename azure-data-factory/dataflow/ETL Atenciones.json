{
	"name": "ETL Atenciones",
	"properties": {
		"folder": {
			"name": "Dataflow Atenciones"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_atenciones",
						"type": "DatasetReference"
					},
					"name": "BaseAtencionesConsolidada"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adls_atenciones_parquet",
						"type": "DatasetReference"
					},
					"name": "AtencionesParquet"
				}
			],
			"transformations": [
				{
					"name": "SeleccionarColumnas"
				},
				{
					"name": "ColumnasCalculadas"
				},
				{
					"name": "AsignarTipoDato"
				}
			],
			"scriptLines": [
				"source(output(",
				"          AtencionID as string,",
				"          {Numero Ticket} as string,",
				"          Agencia as string,",
				"          {Semana Visita} as string,",
				"          {Tipo Atencion} as string,",
				"          ProveedorID as string,",
				"          Proveedor as string,",
				"          Unidades as string,",
				"          {Costo Atencion} as string,",
				"          {Numero OS/OC} as string,",
				"          {Codigo Conformidad} as string,",
				"          Zona as string,",
				"          FechaImportacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> BaseAtencionesConsolidada",
				"BaseAtencionesConsolidada select(mapColumn(",
				"          atencion_id = AtencionID,",
				"          numero_ticket = {Numero Ticket},",
				"          semana_visita = {Semana Visita},",
				"          tipo_atencion = {Tipo Atencion},",
				"          proveedor_id = ProveedorID,",
				"          proveedor = Proveedor,",
				"          unidades = Unidades,",
				"          costo_atencion = {Costo Atencion},",
				"          numero_os_oc = {Numero OS/OC},",
				"          codigo_conformidad = {Codigo Conformidad},",
				"          zona = Zona",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SeleccionarColumnas",
				"SeleccionarColumnas derive(costo_atencion = toFloat(iif( in([\"COSTO CERO\", \"SIN COSTO\"], upper(trim(costo_atencion))), \"0\", replace(costo_atencion, \",\", \".\"))),",
				"          zona = substringIndex(substringIndex(zona, \".\", 1), \" \", -1),",
				"          fecha_carga = currentUTC()) ~> ColumnasCalculadas",
				"ColumnasCalculadas cast(output(",
				"          atencion_id as integer,",
				"          proveedor_id as integer,",
				"          unidades as integer",
				"     ),",
				"     errors: true) ~> AsignarTipoDato",
				"AsignarTipoDato sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          atencion_id as integer,",
				"          numero_ticket as string,",
				"          semana_visita as string,",
				"          tipo_atencion as string,",
				"          proveedor_id as integer,",
				"          proveedor as string,",
				"          unidades as integer,",
				"          costo_atencion as float,",
				"          numero_os_oc as string,",
				"          codigo_conformidad as string,",
				"          zona as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     format: 'parquet',",
				"     partitionFileNames:['Atenciones.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> AtencionesParquet"
			]
		}
	}
}