{
	"name": "Pipeline Compras",
	"properties": {
		"activities": [
			{
				"name": "ComprasOnline",
				"type": "Validation",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_github_compras_online",
						"type": "DatasetReference"
					},
					"timeout": "0.12:00:00",
					"sleep": 10
				}
			},
			{
				"name": "ComprasPresencial",
				"type": "Validation",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_github_compras_presencial",
						"type": "DatasetReference"
					},
					"timeout": "0.12:00:00",
					"sleep": 10
				}
			},
			{
				"name": "DetalleCompras",
				"type": "GetMetadata",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_ftp_detalle_compras",
						"type": "DatasetReference"
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "FtpReadSettings",
						"recursive": true,
						"enablePartitionDiscovery": false,
						"useBinaryTransfer": true,
						"disableChunking": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "FiltrarBase",
				"type": "Filter",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [
					{
						"activity": "DetalleCompras",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('DetalleCompras').output.childItems",
						"type": "Expression"
					},
					"condition": {
						"value": "@endswith(item().name, '.csv')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Validar Ejecucion ETL",
				"type": "IfCondition",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [
					{
						"activity": "ComprasOnline",
						"dependencyConditions": [
							"Succeeded"
						]
					},
					{
						"activity": "ComprasPresencial",
						"dependencyConditions": [
							"Succeeded"
						]
					},
					{
						"activity": "FiltrarBase",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@and(activity('ComprasOnline').output.exists, and(activity('ComprasPresencial').output.exists, equals(activity('FiltrarBase').output.FilteredItemsCount, 4)))",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Actualizar Fecha Evaluacion",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Bronze Layer",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "fecha_evaluacion",
					"value": {
						"value": "2025-06-16",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Bronze Layer",
				"type": "ExecutePipeline",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "01_Bronze_Layer",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true
				}
			},
			{
				"name": "Silver Layer",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "Actualizar Fecha Evaluacion",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "02_Silver_layer",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"fecha": {
							"value": "@variables('fecha_evaluacion')",
							"type": "Expression"
						}
					}
				}
			}
		],
		"variables": {
			"fecha_evaluacion": {
				"type": "String",
				"defaultValue": "2025-06-01"
			}
		},
		"folder": {
			"name": "Sales Store ETL"
		},
		"annotations": [],
		"lastPublishTime": "2025-08-20T07:43:26Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}